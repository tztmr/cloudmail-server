#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_PATH="${ROOT_DIR}/cloudmail.sh"

source "$SCRIPT_PATH"

tmp_env="$(mktemp)"
trap 'rm -f "$tmp_env"' EXIT

cat > "$tmp_env" <<'EOF'
JWT_SECRET=请替换为至少32位强随机字符串
ADMIN=admin@yourdomain.com
DOMAIN=["yourdomain.com"]
EOF

ENV_FILE="$tmp_env"

env_has_placeholder_values

set_env_value "JWT_SECRET" 'abc/123'
set_env_value "ADMIN" 'root@example.com'
set_env_value "DOMAIN" '["mx.example.com"]'

grep -q '^JWT_SECRET=abc/123$' "$tmp_env"
grep -q '^ADMIN=root@example.com$' "$tmp_env"
grep -q '^\QDOMAIN=["mx.example.com"]\E$' "$tmp_env" 2>/dev/null || grep -Fqx 'DOMAIN=["mx.example.com"]' "$tmp_env"

tmp_project="$(mktemp -d)"
tmp_script_dir="$(mktemp -d)"
tmp_manual_project="$(mktemp -d)"
trap 'rm -f "$tmp_env"; rm -rf "$tmp_project" "$tmp_script_dir" "$tmp_manual_project"' EXIT

touch "$tmp_project/docker-compose.yml" "$tmp_project/Dockerfile"
touch "$tmp_manual_project/docker-compose.yml" "$tmp_manual_project/Dockerfile"

SCRIPT_DIR="$tmp_script_dir"
PROJECT_ROOT=""
PROJECT_SOURCE=""

(
  cd "$tmp_project"
  discover_local_project_root
  [[ "$PROJECT_ROOT" == "$tmp_project" ]]
  [[ "$PROJECT_SOURCE" == "local" ]]
)

prompt_default() {
  printf '%s' "$tmp_manual_project"
}

PROJECT_ROOT=""
PROJECT_SOURCE=""
prompt_for_project_root
[[ "$PROJECT_ROOT" == "$tmp_manual_project" ]]
[[ "$PROJECT_SOURCE" == "local" ]]

tmp_cloned_project="$(mktemp -d)"
prompt_marker="$(mktemp)"
rm -f "$prompt_marker"
trap 'rm -f "$tmp_env" "$prompt_marker"; rm -rf "$tmp_project" "$tmp_script_dir" "$tmp_manual_project" "$tmp_cloned_project"' EXIT
touch "$tmp_cloned_project/docker-compose.yml" "$tmp_cloned_project/Dockerfile"

is_interactive() { return 0; }
discover_local_project_root() { return 1; }
prompt_default() {
  : > "$prompt_marker"
  printf '%s' ""
}
clone_or_update_repo() {
  PROJECT_ROOT="$tmp_cloned_project"
  PROJECT_SOURCE="git"
}
ensure_project_root() { :; }
detect_env_file() { :; }
detect_public_ports() { :; }
install_docker_if_needed() { :; }

prepare_runtime
[[ "$PROJECT_ROOT" == "$tmp_cloned_project" ]]
[[ "$PROJECT_SOURCE" == "git" ]]
[[ ! -f "$prompt_marker" ]]
